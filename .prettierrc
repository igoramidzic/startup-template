{
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": true,
  "printWidth": 120,
  "tabWidth": 2,
  "endOfLine": "auto",
  "bracketSpacing": true,
  "overrides": [
    {
      "files": "*.scss",
      "options": {
        "singleQuote": false
      }
    },
    {
      "files": "*.html",
      "options": {
        "printWidth": 120,
        "parser": "angular"
      }
    }
  ],
  "plugins": ["prettier-plugin-organize-imports", "prettier-plugin-astro", "prettier-plugin-tailwindcss"]
}
