---
import { BarChart, LineChart, PieChart } from '@lucide/astro';
---

<section class="bg-background">
  <div class="feature-section">
    <div class="mx-auto max-w-[60rem]">
      <p class="text-primary mb-3 text-xs font-medium tracking-wider uppercase">Reports</p>
      <div class="mb-12 max-w-2xl sm:mb-14">
        <h2 class="mb-4 text-3xl font-medium tracking-normal text-balance sm:text-4xl">
          Know exactly where things stand.
        </h2>
        <p class="text-muted-foreground text-base leading-relaxed font-light">
          Reports answer the questions your team actually has: are we trending the right way, what is driving the
          numbers, am I making progress week over week.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-x-10 gap-y-10 sm:grid-cols-2 md:grid-cols-3">
        <div>
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-600/10">
            <LineChart size={20} stroke-width={1.5} class="text-emerald-600" />
          </div>
          <h3 class="mb-2 text-base font-semibold tracking-tight">Trends</h3>
          <p class="text-muted-foreground text-sm leading-relaxed font-light">
            Every metric in one view, tracked over time so progress is impossible to miss.
          </p>
        </div>
        <div>
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10">
            <PieChart size={20} stroke-width={1.5} class="text-amber-600" />
          </div>
          <h3 class="mb-2 text-base font-semibold tracking-tight">Breakdown</h3>
          <p class="text-muted-foreground text-sm leading-relaxed font-light">
            See exactly which segments drive the numbers and which ones are quietly underperforming.
          </p>
        </div>
        <div>
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-blue-600/10">
            <BarChart size={20} stroke-width={1.5} class="text-blue-600" />
          </div>
          <h3 class="mb-2 text-base font-semibold tracking-tight">Comparison</h3>
          <p class="text-muted-foreground text-sm leading-relaxed font-light">
            The single chart that answers "did we make progress this period" without any mental math.
          </p>
        </div>
      </div>

      <div class="mt-14 sm:mt-16">
        <div class="img-gradient-accent aspect-[16/10] h-auto w-full rounded border-3"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-section {
    padding: 4rem 1.25rem;
  }
  @media (min-width: 640px) {
    .feature-section {
      padding: 5rem 1.25rem;
    }
  }
</style>
