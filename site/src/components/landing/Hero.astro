---
import { ArrowRight, Gift, Lock, Zap } from '@lucide/astro';
import { links, siteConfig } from '../../config';
---

<section id="hero" class="flex flex-1 items-center justify-center px-5 py-24 md:pt-32 md:pb-12">
  <div class="mx-auto flex w-full max-w-[60rem] flex-col items-start">
    <a
      href="#features"
      class="text-foreground bg-accent/60 hover:bg-accent mb-8 inline-flex items-center gap-2 rounded-full py-1 pr-3 pl-1 text-xs font-medium transition-colors"
    >
      <span class="bg-primary text-primary-foreground rounded-full px-2 py-0.5 text-[10px] uppercase">NEW</span>
      <span>Announcing our v2 release</span>
      <ArrowRight size={12} />
    </a>

    <h1 class="max-w-3xl text-left text-3xl font-medium tracking-normal text-balance sm:text-4xl lg:text-5xl">
      A short, bold headline for your product.
    </h1>

    <p class="text-muted-foreground mt-6 max-w-xl text-left text-base leading-relaxed font-light sm:text-lg">
      {siteConfig.name} is a placeholder description for your SaaS. Replace this paragraph with the value proposition
      that explains what you do and who you do it for in plain language.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-5">
      <a
        href={links.signup}
        class="bg-foreground text-background inline-flex h-11 items-center gap-2 rounded-full px-5 text-sm font-medium transition-opacity hover:opacity-90"
      >
        <span>Start free</span>
      </a>
      <a href="#features" class="text-foreground inline-flex items-center gap-1.5 text-sm font-medium hover:underline">
        See how it works
        <ArrowRight size={14} />
      </a>
    </div>

    <div class="text-muted-foreground mt-8 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm font-light">
      <span class="flex items-center gap-1.5">
        <Gift size={14} stroke-width={1.5} />
        7-day free trial
      </span>
      <span class="flex items-center gap-1.5">
        <Zap size={14} stroke-width={1.5} />
        2-minute setup
      </span>
      <span class="flex items-center gap-1.5">
        <Lock size={14} stroke-width={1.5} />
        Enterprise-grade security
      </span>
    </div>
  </div>
</section>

<section class="w-full px-5 pb-16 sm:pb-20">
  <div class="mx-auto max-w-[60rem]">
    <div class="img-gradient-accent aspect-[16/10] h-auto w-full rounded border-3"></div>
  </div>
</section>
