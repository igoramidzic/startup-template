---
import { ArrowRight } from '@lucide/astro';
import { links } from '../../config';
---

<section class="px-5 py-16 sm:py-20">
  <div class="mx-auto max-w-[60rem]">
    <div class="bg-primary/10 mb-10 flex h-14 w-14 items-center justify-center rounded-2xl">
      <span class="text-primary text-2xl font-semibold">A</span>
    </div>

    <p class="text-primary mb-3 text-xs font-medium tracking-wider uppercase">Why Acme</p>

    <h2 class="mb-6 max-w-2xl text-3xl font-medium tracking-normal text-balance sm:text-4xl">
      Stop guessing. Start knowing.
    </h2>

    <p class="text-muted-foreground mb-10 max-w-2xl text-base leading-relaxed font-light sm:text-lg sm:leading-relaxed">
      Most teams have no idea what is actually happening across their stack. When every signal has a place to land
      before it leaves the system, decisions become deliberate instead of accidental. That is the whole promise of Acme,
      and that is what we are built around.
    </p>

    <div class="mb-6 flex flex-wrap items-center gap-5">
      <a
        href={links.signup}
        class="bg-foreground text-background inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
      >
        Start free
      </a>
      <a href="#features" class="text-foreground inline-flex items-center gap-1.5 text-sm font-medium hover:underline">
        See the features
        <ArrowRight size={14} />
      </a>
    </div>

    <p class="text-muted-foreground text-sm font-light">7-day free trial. Cancel any time. 2-minute setup.</p>
  </div>
</section>
