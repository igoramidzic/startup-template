---
import { Bell, CalendarClock, Repeat2 } from '@lucide/astro';
---

<section class="bg-background">
  <div class="feature-section">
    <div class="mx-auto max-w-[60rem]">
      <p class="text-primary mb-3 text-xs font-medium tracking-wider uppercase">Visibility</p>
      <div class="mb-12 max-w-2xl sm:mb-14">
        <h2 class="mb-4 text-3xl font-medium tracking-normal text-balance sm:text-4xl">
          See what's coming before it lands.
        </h2>
        <p class="text-muted-foreground text-base leading-relaxed font-light">
          Get ahead of what is about to happen. Acme shows you the future of your data so nothing arrives by surprise.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-x-10 gap-y-10 sm:grid-cols-2 md:grid-cols-3">
        <div>
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-violet-500/10">
            <CalendarClock size={20} stroke-width={1.5} class="text-violet-600" />
          </div>
          <h3 class="mb-2 text-base font-semibold tracking-tight">Scheduled events</h3>
          <p class="text-muted-foreground text-sm leading-relaxed font-light">
            Set up anything that runs on a rhythm. Acme projects them forward so the calendar always reflects reality.
          </p>
        </div>
        <div>
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-yellow-600/10">
            <Bell size={20} stroke-width={1.5} class="text-yellow-600" />
          </div>
          <h3 class="mb-2 text-base font-semibold tracking-tight">Upcoming view</h3>
          <p class="text-muted-foreground text-sm leading-relaxed font-light">
            A running list of what is about to happen, so the team is never caught off guard mid-cycle.
          </p>
        </div>
        <div>
          <div class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-cyan-600/10">
            <Repeat2 size={20} stroke-width={1.5} class="text-cyan-600" />
          </div>
          <h3 class="mb-2 text-base font-semibold tracking-tight">Audit log</h3>
          <p class="text-muted-foreground text-sm leading-relaxed font-light">
            One screen shows every recurring event and what it costs you. Cancel, pause, or reroute with confidence.
          </p>
        </div>
      </div>

      <div class="mt-14 sm:mt-16">
        <div class="img-gradient-accent aspect-[16/10] h-auto w-full rounded border-3"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .feature-section {
    padding: 4rem 1.25rem;
  }
  @media (min-width: 640px) {
    .feature-section {
      padding: 5rem 1.25rem;
    }
  }
</style>
