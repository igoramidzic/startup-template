---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags?: string[];
  heroImage?: ImageMetadata;
}

const { title, description, pubDate, slug, tags, heroImage } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
}
---

<a href={`/blog/${slug}`} class="group block">
  {
    heroImage && (
      <Image
        src={heroImage}
        alt={title}
        class="mb-4 aspect-video w-full rounded-lg object-cover grayscale transition-[filter] duration-300 group-hover:grayscale-0"
        loading="lazy"
      />
    )
  }

  <div class="text-muted-foreground mb-2 text-sm">
    <time datetime={pubDate.toISOString()}>
      {formatDate(pubDate)}
    </time>
  </div>

  <h2 class="text-foreground mb-2 text-lg font-bold transition-colors duration-300 group-hover:opacity-70">
    {title}
  </h2>

  <p
    class="text-muted-foreground text-sm leading-relaxed font-light transition-opacity duration-300 group-hover:opacity-80"
  >
    {description}
  </p>
</a>
